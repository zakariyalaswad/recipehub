<!DOCTYPE html>
<html class="light" lang="fr">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Mon Profil - RecipeHub</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700&family=Newsreader:opsz,wght@6..72,600;6..72,700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'surface': '#f4fafd',
                        'primary': '#006d37',
                        'on-primary': '#ffffff',
                        'secondary-container': '#7bf8a1',
                        'on-secondary-container': '#007239',
                        'surface-container-low': '#eef5f7',
                        'on-surface-variant': '#3d4a3e',
                        'error': '#ba1a1a',
                        'surface-container-highest': '#dde4e6'
                    },
                    fontFamily: {
                        'body-md': ['Be Vietnam Pro'],
                        'headline-md': ['Newsreader'],
                        'headline-lg': ['Newsreader'],
                        'headline-xl': ['Newsreader'],
                        'label-md': ['Be Vietnam Pro']
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .profile-shadow {
            box-shadow: 0 4px 20px rgba(46, 204, 113, 0.08);
        }
    </style>
</head>
<body class="bg-surface text-slate-900 font-body-md min-h-screen">
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <nav class="flex justify-between items-center w-full px-8 h-20 max-w-6xl mx-auto">
            <a href="{{ path('app_home') }}" class="text-2xl font-bold text-primary hover:opacity-80 transition-opacity">RecipeHub</a>
            <div class="flex items-center gap-3">
                <a href="{{ path('app_home') }}" class="px-4 py-2 rounded-xl border border-primary text-primary font-label-md hover:bg-primary hover:text-white transition-colors">Accueil</a>
                <a href="{{ path('app_mes_favoris') }}" class="px-4 py-2 rounded-xl bg-secondary-container text-on-secondary-container font-label-md hover:opacity-90 transition-opacity">Mes favoris</a>
                <a href="{{ path('app_logout') }}" class="px-4 py-2 rounded-xl bg-surface-container-low text-slate-700 font-label-md hover:bg-slate-200 transition-colors">Déconnexion</a>
            </div>
        </nav>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <section class="lg:col-span-2 bg-white rounded-3xl p-8 profile-shadow border border-slate-200">
                <div class="flex flex-col sm:flex-row sm:items-center gap-6 pb-8 border-b border-slate-200">
                    <div class="w-24 h-24 rounded-full bg-gradient-to-br from-primary to-[#004d28] flex items-center justify-center text-white text-3xl font-bold">
                        {{ app.user.pseudo|slice(0, 2)|upper }}
                    </div>
                    <div>
                        <h1 class="text-4xl font-headline-xl font-bold text-slate-900">Mon Profil</h1>
                        <p class="text-slate-600 mt-2">Votre espace personnel sur RecipeHub</p>
                        <div class="mt-3 flex flex-wrap gap-2">
                            {% if 'ROLE_ADMIN' in app.user.roles %}
                                <span class="px-3 py-1 rounded-full bg-red-100 text-red-700 text-xs font-bold">Administrateur</span>
                            {% else %}
                                <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold">Utilisateur</span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-8">
                    <div class="bg-surface-container-low rounded-2xl p-5">
                        <p class="text-sm text-on-surface-variant">Pseudo</p>
                        <p class="text-lg font-semibold mt-1">{{ app.user.pseudo }}</p>
                    </div>
                    <div class="bg-surface-container-low rounded-2xl p-5">
                        <p class="text-sm text-on-surface-variant">Email</p>
                        <p class="text-lg font-semibold mt-1">{{ app.user.email }}</p>
                    </div>
                    <div class="bg-surface-container-low rounded-2xl p-5">
                        <p class="text-sm text-on-surface-variant">Mes recettes</p>
                        <p class="text-lg font-semibold mt-1">{{ recipeCount }}</p>
                    </div>
                    <div class="bg-surface-container-low rounded-2xl p-5">
                        <p class="text-sm text-on-surface-variant">Mes favoris</p>
                        <p class="text-lg font-semibold mt-1">{{ favoriteCount }}</p>
                    </div>
                </div>
            </section>

            <aside class="bg-white rounded-3xl p-8 profile-shadow border border-slate-200 h-fit">
                <h2 class="text-2xl font-headline-lg font-bold text-slate-900 mb-6">Actions rapides</h2>
                <div class="space-y-3">
                    <a href="{{ path('app_mes_favoris') }}" class="block w-full text-center px-4 py-3 rounded-xl bg-primary text-on-primary font-semibold hover:opacity-90 transition-opacity">Voir mes favoris</a>
                    <a href="{{ path('app_home') }}" class="block w-full text-center px-4 py-3 rounded-xl border border-slate-200 text-slate-700 font-semibold hover:bg-slate-50 transition-colors">Retour à l'accueil</a>
                    <a href="{{ path('app_login') }}" class="block w-full text-center px-4 py-3 rounded-xl bg-surface-container-low text-slate-700 font-semibold hover:bg-slate-200 transition-colors">Changer de compte</a>
                </div>

                <div class="mt-8 rounded-2xl bg-slate-50 p-5">
                    <p class="text-sm text-on-surface-variant">Membre depuis</p>
                    <p class="text-lg font-semibold mt-1">
                        {% if app.user.dateCreation %}
                            {{ app.user.dateCreation|date('d/m/Y') }}
                        {% else %}
                            N/A
                        {% endif %}
                    </p>
                </div>
            </aside>
        </div>
    </main>
</body>
</html>
