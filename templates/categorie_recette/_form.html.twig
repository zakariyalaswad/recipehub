{% set isEdit = button_label is defined and button_label == 'Update' %}

{{ form_start(form, { attr: { class: 'space-y-8' } }) }}
    {{ form_errors(form) }}

    <div class="space-y-2">
        {{ form_label(form.nom, 'Nom de la Catégorie', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
        {{ form_widget(form.nom, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface', placeholder: 'ex: Desserts Gourmands' } }) }}
        {{ form_help(form.nom) }}
        <p class="text-[12px] text-on-surface-variant opacity-60">Le nom doit être unique et descriptif.</p>
    </div>

    <div class="space-y-2">
        {{ form_label(form.icone, 'Icône / Emoji', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
        {{ form_widget(form.icone, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface', placeholder: '🥗' } }) }}
        <p class="text-[12px] text-on-surface-variant opacity-60">Choisissez un emoji simple pour représenter la catégorie.</p>
    </div>

    <div class="space-y-2">
        {{ form_label(form.description, 'Description', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
        {{ form_widget(form.description, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface', rows: 4, placeholder: 'Décrivez le contenu de cette catégorie pour guider vos cuisiniers...' } }) }}
    </div>

    <div class="pt-6 flex items-center gap-4 border-t border-outline-variant">
        <button class="px-8 py-3 bg-secondary text-on-primary rounded-lg font-label-md hover:bg-primary transition-colors active:scale-95 shadow-lg shadow-primary/20" type="submit">
            {{ button_label|default('Enregistrer') }}
        </button>
        <a class="px-8 py-3 bg-surface-container-high text-on-surface rounded-lg font-label-md hover:bg-surface-dim transition-colors active:scale-95" href="{{ path('app_categorie_recette_index') }}">
            Annuler
        </a>
    </div>
{{ form_end(form) }}
