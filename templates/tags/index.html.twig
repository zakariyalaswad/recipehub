{% extends "base.html.twig" %}

{% block title %}Étiquettes - RecipeHub{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50">
    <!-- Header -->
    <div class="bg-white border-b border-slate-200 p-6 sticky top-0 z-10">
        <div class="max-w-7xl mx-auto">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <a href="{{ path('app_home') }}" class="text-[#006d37] hover:underline text-sm mb-2 inline-block">← RecipeHub</a>
                    <h1 class="text-3xl font-newsreader font-bold text-slate-900">Toutes les Étiquettes</h1>
                </div>
            </div>

            <!-- Search Form -->
            <form method="get" class="flex gap-2">
                <input 
                    type="text" 
                    name="q" 
                    value="{{ search }}" 
                    placeholder="Chercher une étiquette..." 
                    class="flex-1 px-4 py-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-[#006d37] focus:border-transparent"
                >
                <button 
                    type="submit" 
                    class="bg-[#006d37] text-white px-6 py-2 rounded-lg hover:bg-[#005a2d] transition-colors font-medium"
                >
                    Chercher
                </button>
                {% if search %}
                    <a 
                        href="{{ path('app_tags_index') }}" 
                        class="bg-slate-200 text-slate-700 px-4 py-2 rounded-lg hover:bg-slate-300 transition-colors font-medium"
                    >
                        Réinitialiser
                    </a>
                {% endif %}
            </form>
        </div>
    </div>

    <!-- Main Content -->
    <main class="p-6">
        <div class="max-w-7xl mx-auto">
            <!-- Stats -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-recipe">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-slate-600 font-medium">Total des Étiquettes</p>
                            <p class="text-3xl font-bold text-slate-900 mt-2">{{ totalTags }}</p>
                        </div>
                        <svg class="w-12 h-12 text-[#006d37]/20" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.63 5.84C17.27 5.33 16.67 5 16 5L5 19h14c.63 0 1.23-.33 1.59-.84L17.63 5.84zM16 3h-1c-.82 0-1.58.35-2.11.92L6.5 13.5h11L16 3z"/>
                        </svg>
                    </div>
                </div>

                <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-recipe">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-slate-600 font-medium">Résultats</p>
                            <p class="text-3xl font-bold text-slate-900 mt-2">{{ tags|length }}</p>
                        </div>
                        <svg class="w-12 h-12 text-[#006d37]/20" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"/>
                        </svg>
                    </div>
                </div>

                <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-recipe">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm text-slate-600 font-medium">Navigation</p>
                            <div class="flex gap-2 mt-2">
                                <a href="{{ path('app_home') }}" class="text-xs bg-[#006d37]/10 text-[#006d37] px-2 py-1 rounded hover:bg-[#006d37]/20 transition-colors">Accueil</a>
                                <a href="{{ path('app_chef_dashboard') }}" class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded hover:bg-purple-200 transition-colors">Dashboard</a>
                            </div>
                        </div>
                        <svg class="w-12 h-12 text-[#006d37]/20" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm0-13c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5z"/>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Tags Grid -->
            <div>
                {% if tags is empty %}
                    <div class="bg-white rounded-xl p-12 text-center border border-slate-200">
                        <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.63 5.84C17.27 5.33 16.67 5 16 5L5 19h14c.63 0 1.23-.33 1.59-.84L17.63 5.84zM16 3h-1c-.82 0-1.58.35-2.11.92L6.5 13.5h11L16 3z"/>
                        </svg>
                        <p class="text-slate-600 text-lg">Aucune étiquette trouvée.</p>
                        {% if search %}
                            <a href="{{ path('app_tags_index') }}" class="inline-block mt-4 text-[#006d37] hover:underline">
                                Voir toutes les étiquettes
                            </a>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {% for tag in tags %}
                            <div class="bg-white rounded-xl overflow-hidden border border-slate-200 shadow-recipe hover:shadow-lg transition-shadow">
                                <!-- Header with color -->
                                <div class="h-2 {% if tag.couleur %}bg-[{{ tag.couleur }}]{% else %}bg-slate-300{% endif %}"></div>

                                <!-- Content -->
                                <div class="p-6">
                                    <div class="flex items-center justify-between mb-4">
                                        <h3 class="font-newsreader font-bold text-xl text-slate-900">{{ tag.nom }}</h3>
                                        {% if tag.couleur %}
                                            <div class="w-8 h-8 rounded-lg border-2 border-slate-200" style="background-color: {{ tag.couleur }};"></div>
                                        {% endif %}
                                    </div>

                                    <!-- Recipe Count -->
                                    <div class="mb-4 p-3 bg-slate-50 rounded-lg">
                                        <p class="text-sm text-slate-600">Recettes</p>
                                        <p class="text-2xl font-bold text-slate-900">{{ tag.recettes|length }}</p>
                                    </div>

                                    <!-- Recipes List Preview -->
                                    {% if tag.recettes is not empty %}
                                        <div class="mb-4">
                                            <p class="text-sm text-slate-600 font-medium mb-2">Recettes associées:</p>
                                            <div class="flex flex-wrap gap-2">
                                                {% for recette in tag.recettes|slice(0, 3) %}
                                                    <a href="{{ path('app_recette_show', {'id': recette.id}) }}" class="inline-block text-xs bg-[#006d37]/10 text-[#006d37] px-3 py-1 rounded-full hover:bg-[#006d37]/20 transition-colors">
                                                        {{ recette.titre|length > 15 ? recette.titre|slice(0, 15) ~ '...' : recette.titre }}
                                                    </a>
                                                {% endfor %}
                                                {% if tag.recettes|length > 3 %}
                                                    <span class="text-xs text-slate-500">+{{ tag.recettes|length - 3 }} more</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% else %}
                                        <div class="mb-4 p-3 bg-yellow-50 rounded-lg">
                                            <p class="text-sm text-yellow-700">Aucune recette avec cette étiquette</p>
                                        </div>
                                    {% endif %}

                                    <!-- View Button -->
                                    <a href="{{ path('app_tags_index', {'q': tag.nom}) }}" class="block w-full bg-[#006d37] text-white text-center font-medium py-2 rounded-lg hover:bg-[#005a2d] transition-colors">
                                        Filtrer par étiquette
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                <!-- Pagination -->
                {% if totalPages > 1 %}
                    <div class="mt-8 flex justify-center items-center gap-2">
                        {% if currentPage > 1 %}
                            <a href="{{ path('app_tags_index', {'page': 1, 'q': search}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">
                                &laquo;
                            </a>
                            <a href="{{ path('app_tags_index', {'page': currentPage - 1, 'q': search}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">
                                &lt;
                            </a>
                        {% endif %}

                        {% for page in 1..totalPages %}
                            {% if page == currentPage %}
                                <span class="px-3 py-2 rounded-lg bg-[#006d37] text-white font-medium">{{ page }}</span>
                            {% elseif page >= currentPage - 2 and page <= currentPage + 2 %}
                                <a href="{{ path('app_tags_index', {'page': page, 'q': search}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">{{ page }}</a>
                            {% endif %}
                        {% endfor %}

                        {% if currentPage < totalPages %}
                            <a href="{{ path('app_tags_index', {'page': currentPage + 1, 'q': search}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">
                                &gt;
                            </a>
                            <a href="{{ path('app_tags_index', {'page': totalPages, 'q': search}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">
                                &raquo;
                            </a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
    </main>
</div>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
{% endblock %}
