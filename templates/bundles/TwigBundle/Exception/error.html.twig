<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>RecipeHub - Error</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700&family=Newsreader:opsz,wght@6..72,600;6..72,700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'on-background': '#161d1f',
                        'surface': '#f4fafd',
                        'primary': '#006d37',
                        'on-primary': '#ffffff',
                        'secondary-container': '#7bf8a1',
                        'on-secondary-container': '#007239',
                        'surface-container-low': '#eef5f7',
                        'on-surface-variant': '#3d4a3e',
                        'error': '#ba1a1a',
                        'surface-container-highest': '#dde4e6'
                    },
                    borderRadius: {
                        DEFAULT: '0.25rem',
                        lg: '0.5rem',
                        xl: '0.75rem',
                        full: '9999px'
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-surface text-black font-sans min-h-screen flex flex-col">
    <header class="bg-white shadow sticky top-0 z-50">
        <nav class="flex justify-between items-center w-full px-8 h-20 max-w-6xl mx-auto">
            <a href="{{ path('app_home') }}" class="text-2xl font-bold text-primary hover:opacity-80 transition-opacity">RecipeHub</a>
        </nav>
    </header>

    <main class="flex-1 flex items-center justify-center px-4 py-12">
        <div class="max-w-2xl w-full text-center">
            <div class="mb-8">
                <div class="text-9xl font-bold text-error opacity-20 mb-4">{{ status_code }}</div>
                <span class="material-symbols-outlined text-8xl text-error opacity-40 block">error</span>
            </div>

            <div class="space-y-6">
                <h1 class="text-4xl font-bold text-black">An Error Occurred</h1>
                <p class="text-lg text-gray-600 max-w-md mx-auto">
                    We encountered an unexpected error. Please try again or contact support.
                </p>

                <div class="bg-gray-100 rounded-lg p-4 mt-8 text-left">
                    <p class="text-sm text-gray-600 font-mono">
                        <span class="font-bold">Status:</span> {{ status_code }}
                    </p>
                    {% if status_text %}
                    <p class="text-sm text-gray-600 font-mono">
                        <span class="font-bold">Message:</span> {{ status_text }}
                    </p>
                    {% endif %}
                </div>

                <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-12">
                    <a href="{{ path('app_home') }}" class="px-8 py-3 bg-primary text-white rounded-xl font-semibold hover:scale-105 transition-transform inline-flex items-center gap-2">
                        <span class="material-symbols-outlined">home</span>
                        Back to Home
                    </a>
                    <a href="{{ path('app_login') }}" class="px-8 py-3 bg-secondary-container text-on-secondary-container rounded-xl font-semibold hover:scale-105 transition-transform inline-flex items-center gap-2">
                        <span class="material-symbols-outlined">login</span>
                        Go to Login
                    </a>
                </div>
            </div>
        </div>
    </main>

    <footer class="bg-gray-100 border-t py-8 mt-auto">
        <div class="max-w-6xl mx-auto px-8 text-center">
            <p class="text-gray-600 text-sm">RecipeHub © 2026</p>
        </div>
    </footer>
</body>
</html>
