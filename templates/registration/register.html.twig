{% extends 'base.html.twig' %}

{% block title %}S'inscrire - RecipeHub{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              colors: {
                "secondary-fixed": "#7efba4",
                "tertiary-fixed": "#e1e3e1",
                "surface-container-high": "#e2e9ec",
                "secondary": "#006d37",
                "surface-container-highest": "#dde4e6",
                "on-primary-fixed-variant": "#005228",
                "on-primary-fixed": "#00210c",
                "tertiary-fixed-dim": "#c5c7c5",
                "tertiary": "#5c5f5e",
                "surface-dim": "#d4dbdd",
                "secondary-container": "#7bf8a1",
                "on-primary": "#ffffff",
                "on-primary-container": "#005027",
                "on-secondary-fixed": "#00210c",
                "on-background": "#161d1f",
                "on-error": "#ffffff",
                "inverse-surface": "#2b3234",
                "outline-variant": "#bbcbbb",
                "on-secondary-fixed-variant": "#005228",
                "secondary-fixed-dim": "#61de8a",
                "on-tertiary-fixed-variant": "#444746",
                "inverse-primary": "#4ae183",
                "surface-bright": "#f4fafd",
                "primary-fixed-dim": "#4ae183",
                "surface-container": "#e8eff1",
                "on-secondary-container": "#007239",
                "inverse-on-surface": "#ebf2f4",
                "outline": "#6c7b6d",
                "error": "#ba1a1a",
                "surface-variant": "#dde4e6",
                "surface-container-low": "#eef5f7",
                "on-surface": "#161d1f",
                "on-error-container": "#93000a",
                "surface": "#f4fafd",
                "primary-fixed": "#6bfe9c",
                "primary": "#006d37",
                "tertiary-container": "#b1b3b2",
                "primary-container": "#2ecc71",
                "on-tertiary-fixed": "#191c1b",
                "background": "#f4fafd",
                "on-tertiary-container": "#424644",
                "surface-container-lowest": "#ffffff",
                "on-tertiary": "#ffffff",
                "on-surface-variant": "#3d4a3e",
                "surface-tint": "#006d37",
                "error-container": "#ffdad6",
                "on-secondary": "#ffffff"
              },
              borderRadius: {
                DEFAULT: "0.25rem",
                lg: "0.5rem",
                xl: "0.75rem",
                full: "9999px"
              },
              spacing: {
                container-max: "1200px",
                gutter: "24px",
                unit: "8px",
                "margin-desktop": "40px",
                "margin-mobile": "16px"
              },
              fontFamily: {
                "headline-xl": ["Newsreader"],
                "body-lg": ["Be Vietnam Pro"],
                "body-md": ["Be Vietnam Pro"],
                "label-md": ["Be Vietnam Pro"],
                "headline-md": ["Newsreader"],
                "headline-lg": ["Newsreader"],
                "headline-lg-mobile": ["Newsreader"]
              },
              fontSize: {
                "headline-xl": ["48px", { lineHeight: "56px", fontWeight: "700" }],
                "body-lg": ["18px", { lineHeight: "28px", fontWeight: "400" }],
                "body-md": ["16px", { lineHeight: "24px", fontWeight: "400" }],
                "label-md": ["14px", { lineHeight: "20px", letterSpacing: "0.02em", fontWeight: "600" }],
                "headline-md": ["24px", { lineHeight: "32px", fontWeight: "600" }],
                "headline-lg": ["32px", { lineHeight: "40px", fontWeight: "600" }],
                "headline-lg-mobile": ["28px", { lineHeight: "36px", fontWeight: "600" }]
              }
            },
          },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body { font-family: 'Be Vietnam Pro', sans-serif; }
        h1, h2, h3 { font-family: 'Newsreader', serif; }
        .auth-shadow { box-shadow: 0 4px 20px rgba(46, 204, 113, 0.08); }
    </style>
{% endblock %}

{% block body %}
    <div class="bg-surface text-on-surface min-h-screen flex flex-col">
        <main class="flex-grow flex items-center justify-center py-12 px-margin-mobile md:px-margin-desktop relative overflow-hidden">
            <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-secondary-container/20 rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-96 h-96 bg-primary-container/10 rounded-full blur-3xl"></div>

            <div class="w-full max-w-lg bg-surface-container-lowest rounded-3xl auth-shadow p-8 md:p-12 relative z-10 border border-outline-variant/30">
                <div class="text-center mb-10">
                    <h1 class="font-headline-xl text-headline-xl text-primary mb-2">Créez votre compte</h1>
                    <p class="font-body-md text-body-md text-on-surface-variant">Rejoignez la communauté RecipeHub et commencez votre aventure culinaire.</p>
                </div>

                {% for flash_error in app.flashes('verify_email_error') %}
                    <div class="mb-6 rounded-xl border border-error/20 bg-error-container/60 text-on-error-container px-4 py-3 text-sm">{{ flash_error }}</div>
                {% endfor %}

                {{ form_start(registrationForm, { attr: { class: 'space-y-6' } }) }}
                    {{ form_errors(registrationForm) }}

                    <div class="space-y-2">
                        {{ form_label(registrationForm.pseudo, 'Nom complet', { label_attr: { class: 'block font-label-md text-label-md text-on-surface-variant ml-1' } }) }}
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">person</span>
                            {{ form_widget(registrationForm.pseudo, { attr: { class: 'w-full pl-10 pr-4 py-3 bg-surface rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-body-md text-on-surface', placeholder: 'Jean Dupont' } }) }}
                        </div>
                    </div>

                    <div class="space-y-2">
                        {{ form_label(registrationForm.email, 'Adresse e-mail', { label_attr: { class: 'block font-label-md text-label-md text-on-surface-variant ml-1' } }) }}
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">mail</span>
                            {{ form_widget(registrationForm.email, { attr: { class: 'w-full pl-10 pr-4 py-3 bg-surface rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-body-md text-on-surface', placeholder: 'nom@exemple.com' } }) }}
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-2">
                            {{ form_label(registrationForm.plainPassword, 'Mot de passe', { label_attr: { class: 'block font-label-md text-label-md text-on-surface-variant ml-1' } }) }}
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">lock</span>
                                {{ form_widget(registrationForm.plainPassword, { attr: { class: 'w-full pl-10 pr-4 py-3 bg-surface rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-body-md text-on-surface', placeholder: '••••••••' } }) }}
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label class="block font-label-md text-label-md text-on-surface-variant ml-1" for="confirm_password">Confirmation</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">key</span>
                                <input class="w-full pl-10 pr-4 py-3 bg-surface rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-body-md text-on-surface" id="confirm_password" name="confirm_password" placeholder="••••••••" type="password"/>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-3 pt-2">
                        <label class="flex items-start gap-3 cursor-pointer group">
                            <div class="relative flex items-center mt-0.5">
                                {{ form_widget(registrationForm.agreeTerms, { attr: { class: 'peer appearance-none w-5 h-5 border-2 border-outline-variant rounded-md checked:bg-primary checked:border-primary transition-all' } }) }}
                                <span class="material-symbols-outlined absolute text-on-primary scale-0 peer-checked:scale-100 transition-transform text-[16px] pointer-events-none left-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            </div>
                            <span class="font-body-md text-body-md text-on-surface-variant leading-tight">J'accepte les <a class="text-primary font-semibold hover:underline" href="#">conditions d'utilisation</a> et la politique de confidentialité.</span>
                        </label>
                    </div>

                    <button class="w-full py-4 bg-secondary text-on-primary rounded-lg font-bold text-lg shadow-[0_4px_15px_rgba(0,109,55,0.2)] hover:bg-primary hover:shadow-[0_6px_20px_rgba(0,109,55,0.3)] hover:-translate-y-1 transition-all duration-200 mt-4" type="submit">
                        S'inscrire
                    </button>

                    <p class="text-center font-body-md text-body-md text-on-surface-variant pt-4">
                        Déjà membre ? <a class="text-primary font-bold hover:underline" href="{{ path('app_login') }}">Connectez-vous ici</a>
                    </p>
                {{ form_end(registrationForm) }}

            </div>
        </main>
    </div>
{% endblock %}