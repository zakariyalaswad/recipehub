{{ form_start(form, { attr: { class: 'space-y-8' } }) }}
    {{ form_errors(form) }}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="space-y-2">
            {{ form_label(form.titre, 'Titre', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
            {{ form_widget(form.titre, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface', placeholder: 'Chocolate and peanut butter overnight oats' } }) }}
        </div>
        <div class="space-y-2">
            {{ form_label(form.categorie, 'Catégorie', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
            {{ form_widget(form.categorie, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface' } }) }}
        </div>
    </div>

    <div class="space-y-2">
        {{ form_label(form.description, 'Description', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
        {{ form_widget(form.description, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface', rows: 4, placeholder: 'Décrivez la recette en quelques lignes...' } }) }}
    </div>

    <div class="space-y-2">
        {{ form_label(form.instructions, 'Instructions', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
        {{ form_widget(form.instructions, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface', rows: 6, placeholder: 'Étape 1... Étape 2... Étape 3...' } }) }}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="space-y-2">
            {{ form_label(form.tempsPreparation, 'Temps de préparation (min)', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
            {{ form_widget(form.tempsPreparation, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface', placeholder: '10' } }) }}
        </div>
        <div class="space-y-2">
            {{ form_label(form.tempsCuisson, 'Temps de cuisson (min)', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
            {{ form_widget(form.tempsCuisson, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface', placeholder: '15' } }) }}
        </div>
        <div class="space-y-2">
            {{ form_label(form.nbPersonnes, 'Nombre de personnes', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
            {{ form_widget(form.nbPersonnes, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface', placeholder: '2' } }) }}
        </div>
        <div class="space-y-2">
            {{ form_label(form.difficulte, 'Difficulté', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
            {{ form_widget(form.difficulte, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface' } }) }}
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="space-y-4">
            {{ form_label(form.tags, 'Tags', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
            <div class="grid gap-3 rounded-2xl border border-outline-variant bg-surface-container-low p-4 max-h-80 overflow-auto">
                {% for tagChoice in form.tags %}
                    <label class="flex items-center gap-3 rounded-xl bg-white px-4 py-3 border border-outline-variant/40 hover:border-primary transition-colors cursor-pointer">
                        {{ form_widget(tagChoice, { attr: { class: 'h-5 w-5 rounded border-outline-variant text-primary focus:ring-primary' } }) }}
                        <span class="text-sm text-on-surface font-body-md">{{ tagChoice.vars.label }}</span>
                    </label>
                {% endfor %}
            </div>
        </div>

        <div class="space-y-4">
            {{ form_label(form.image, 'Image', { label_attr: { class: 'font-label-md text-on-surface-variant block' } }) }}
            {{ form_widget(form.image, { attr: { class: 'w-full px-4 py-3 rounded-lg border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface bg-white' } }) }}
            <p class="text-[12px] text-on-surface-variant opacity-60">Formats acceptés: JPG, PNG, WEBP. Taille max: 2 Mo.</p>

            <label class="flex items-center gap-3 rounded-2xl border border-outline-variant bg-surface-container-low px-4 py-4 cursor-pointer">
                {{ form_widget(form.publiee, { attr: { class: 'h-5 w-5 rounded border-outline-variant text-primary focus:ring-primary' } }) }}
                <span class="font-body-md text-on-surface">Publier la recette</span>
            </label>
        </div>
    </div>

    <div class="pt-6 flex items-center gap-4 border-t border-outline-variant">
        <button class="px-8 py-3 bg-secondary text-on-primary rounded-lg font-label-md hover:bg-primary transition-colors active:scale-95 shadow-lg shadow-primary/20" type="submit">
            {{ button_label|default('Enregistrer') }}
        </button>
        <a class="px-8 py-3 bg-surface-container-high text-on-surface rounded-lg font-label-md hover:bg-surface-dim transition-colors active:scale-95" href="{{ path('app_recette_index') }}">
            Annuler
        </a>
    </div>
{{ form_end(form) }}
