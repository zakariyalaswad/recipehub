{% extends 'base.html.twig' %}

{% block title %}RecipeHub | Fresh Home Cooking Inspiration{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700&amp;family=Newsreader:opsz,wght@6..72,600;6..72,700&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'on-background': '#161d1f',
                        'surface': '#f4fafd',
                        'surface-bright': '#f4fafd',
                        'on-tertiary-fixed': '#191c1b',
                        'outline': '#6c7b6d',
                        'outline-variant': '#bbcbbb',
                        'on-tertiary-fixed-variant': '#444746',
                        'surface-container-high': '#e2e9ec',
                        'on-secondary-container': '#007239',
                        'primary-container': '#2ecc71',
                        'error': '#ba1a1a',
                        'on-secondary-fixed': '#00210c',
                        'secondary-fixed': '#7efba4',
                        'primary-fixed-dim': '#4ae183',
                        'tertiary': '#5c5f5e',
                        'inverse-primary': '#4ae183',
                        'background': '#f4fafd',
                        'error-container': '#ffdad6',
                        'on-error': '#ffffff',
                        'tertiary-container': '#b1b3b2',
                        'on-surface': '#161d1f',
                        'surface-dim': '#d4dbdd',
                        'secondary-container': '#7bf8a1',
                        'surface-tint': '#006d37',
                        'on-primary-fixed-variant': '#005228',
                        'on-surface-variant': '#3d4a3e',
                        'surface-variant': '#dde4e6',
                        'primary-fixed': '#6bfe9c',
                        'surface-container-highest': '#dde4e6',
                        'inverse-surface': '#2b3234',
                        'inverse-on-surface': '#ebf2f4',
                        'tertiary-fixed': '#e1e3e1',
                        'on-tertiary': '#ffffff',
                        'surface-container': '#e8eff1',
                        'on-error-container': '#93000a',
                        'on-secondary-fixed-variant': '#005228',
                        'surface-container-lowest': '#ffffff',
                        'on-primary': '#ffffff',
                        'on-primary-fixed': '#00210c',
                        'secondary': '#006d37',
                        'surface-container-low': '#eef5f7',
                        'primary': '#006d37',
                        'on-secondary': '#ffffff',
                        'secondary-fixed-dim': '#61de8a',
                        'on-primary-container': '#005027',
                        'on-tertiary-container': '#424644',
                        'tertiary-fixed-dim': '#c5c7c5'
                    },
                    borderRadius: {
                        DEFAULT: '0.25rem',
                        lg: '0.5rem',
                        xl: '0.75rem',
                        full: '9999px'
                    },
                    spacing: {
                        unit: '8px',
                        'container-max': '1200px',
                        gutter: '24px',
                        'margin-mobile': '16px',
                        'margin-desktop': '40px'
                    },
                    fontFamily: {
                        'body-md': ['Be Vietnam Pro'],
                        'headline-lg-mobile': ['Newsreader'],
                        'body-lg': ['Be Vietnam Pro'],
                        'headline-md': ['Newsreader'],
                        'label-md': ['Be Vietnam Pro'],
                        'headline-lg': ['Newsreader'],
                        'headline-xl': ['Newsreader']
                    },
                    fontSize: {
                        'body-md': ['16px', { lineHeight: '24px', fontWeight: '400' }],
                        'headline-lg-mobile': ['28px', { lineHeight: '36px', fontWeight: '600' }],
                        'body-lg': ['18px', { lineHeight: '28px', fontWeight: '400' }],
                        'headline-md': ['24px', { lineHeight: '32px', fontWeight: '600' }],
                        'label-md': ['14px', { lineHeight: '20px', letterSpacing: '0.02em', fontWeight: '600' }],
                        'headline-lg': ['32px', { lineHeight: '40px', fontWeight: '600' }],
                        'headline-xl': ['48px', { lineHeight: '56px', fontWeight: '700' }]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .recipe-shadow {
            box-shadow: 0 4px 20px rgba(46, 204, 113, 0.08);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(8px);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="bg-surface text-on-surface font-body-md min-h-screen">
        <header class="bg-surface dark:bg-background shadow-[0_4px_20px_rgba(46,204,113,0.08)] sticky top-0 z-50">
            <nav class="flex justify-between items-center w-full px-margin-desktop h-20 max-w-container-max mx-auto">
                <a href="{{ path('app_home') }}" class="font-headline-lg text-headline-lg font-bold text-primary dark:text-primary-fixed-dim hover:opacity-80 transition-opacity">RecipeHub</a>
                <div class="hidden md:flex items-center gap-8 font-body-md text-body-md tracking-tight">
                    <a class="text-primary dark:text-primary-fixed-dim font-bold border-b-2 border-primary pb-1" href="#browse">Browse</a>
                    <a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed-dim transition-colors" href="#recipes">Categories</a>
                    <a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed-dim transition-colors" href="#healthy">Healthy</a>
                    <a class="text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed-dim transition-colors" href="#seasonal">Seasonal</a>
                </div>
                <div class="flex items-center gap-4">
                    <div class="relative hidden lg:block">
                        <form method="GET" action="{{ path('app_home') }}" class="flex items-center w-64">
                            <input class="pl-10 pr-4 py-2 rounded-full border-outline-variant bg-surface-container-low focus:ring-primary focus:border-primary w-full text-label-md" placeholder="Search recipe, chef, tags..." type="text" name="search"/>
                            <span class="material-symbols-outlined absolute left-3 text-on-surface-variant pointer-events-none">search</span>
                        </form>
                    </div>
                    {% if app.user %}
                        <div class="flex items-center gap-3">
                            <a href="{{ path('app_profile') }}" class="px-4 py-2 rounded-xl bg-secondary-container text-on-secondary-container font-label-md hover:scale-105 transition-transform duration-200 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">account_circle</span>
                                <span class="hidden sm:inline">Profile</span>
                            </a>
                            <a href="{{ path('app_logout') }}" class="px-4 py-2 rounded-xl bg-surface-container-high text-on-surface-variant font-label-md hover:scale-105 transition-transform duration-200 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">logout</span>
                                <span class="hidden sm:inline">Logout</span>
                            </a>
                        </div>
                    {% else %}
                        <div class="flex items-center gap-3">
                            <a href="{{ path('app_login') }}" class="px-4 py-2 rounded-xl border-2 border-primary text-primary font-label-md hover:bg-primary hover:text-on-primary transition-colors duration-200">Sign In</a>
                            <a href="{{ path('app_register') }}" class="px-6 py-2 rounded-xl bg-primary text-on-primary font-label-md hover:scale-105 transition-transform duration-200">Sign Up</a>
                        </div>
                    {% endif %}
                </div>
            </nav>
        </header>

        {{ include('home/_recipe_detail.html.twig', {
            featuredRecipe: featuredRecipe,
            ingredients: ingredients,
            categories: categories,
            highlights: highlights,
            instructions: instructions,
            nutrition: nutrition,
            author: author,
        }) }}

        <main class="max-w-container-max mx-auto px-margin-desktop py-12">
            <section id="browse" class="mb-20 grid grid-cols-1 md:grid-cols-4 lg:grid-cols-6 gap-4">
                <div class="md:col-span-2 lg:col-span-2 bg-secondary-container p-8 rounded-3xl flex flex-col justify-between">
                    <h3 class="font-headline-md text-headline-md text-on-secondary-container">Popular Categories</h3>
                    <div class="flex flex-wrap gap-2 mt-4">
                        {% for category in categories %}
                            <a href="{{ path('app_home', {'categorie': category.id, 'page': 1}) }}" class="bg-white/50 px-4 py-2 rounded-full text-label-md hover:bg-white transition-colors cursor-pointer">{{ category.nom }}</a>
                        {% endfor %}
                    </div>
                </div>
                <div class="lg:col-span-4 grid grid-cols-2 lg:grid-cols-3 gap-4">
                    {% for item in highlights %}
                        <div class="{{ item.class }} rounded-3xl p-6 recipe-shadow hover:-translate-y-1 transition-transform">
                            <span class="material-symbols-outlined text-primary mb-2">{{ item.icon }}</span>
                            <h4 class="font-bold">{{ item.title }}</h4>
                            <p class="text-[12px] opacity-70">{{ item.description }}</p>
                        </div>
                    {% endfor %}
                </div>
            </section>

            <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20">
                <div class="lg:col-span-7">
                    <h2 class="font-headline-md text-headline-md mb-8">How to make it</h2>
                    <div class="space-y-10">
                        {% for step in instructions %}
                            <div class="flex gap-6 group">
                                <span class="font-headline-xl text-primary opacity-30 group-hover:opacity-100 transition-opacity shrink-0">{{ loop.index }}</span>
                                <div>
                                    <p class="text-body-lg text-on-surface-variant leading-relaxed">{{ step }}</p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                <div class="lg:col-span-5 space-y-8">
                    <div class="bg-surface-container-high rounded-3xl p-8 recipe-shadow">
                        <h3 class="font-headline-md text-headline-md mb-6">Nutrition per serving</h3>
                        <div class="grid grid-cols-2 gap-4">
                            {% for item in nutrition %}
                                <div class="bg-white p-4 rounded-2xl flex flex-col items-center">
                                    <span class="text-label-md text-on-surface-variant uppercase tracking-wider">{{ item.label }}</span>
                                    <span class="text-headline-md font-bold text-primary">{{ item.value }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="flex items-center gap-4 p-6 border border-outline-variant rounded-3xl bg-white">
                        <img class="w-16 h-16 rounded-full object-cover border-2 border-primary" alt="{{ author.name }}" src="{{ author.image }}"/>
                        <div>
                            <h4 class="font-bold text-body-lg">{{ author.name }}</h4>
                            <p class="text-label-md text-on-surface-variant">{{ author.role }}</p>
                            <div class="flex gap-3 mt-2">
                                <span class="material-symbols-outlined text-[18px] text-primary cursor-pointer">share</span>
                                <span class="material-symbols-outlined text-[18px] text-primary cursor-pointer">mail</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Recipes with Search and Category Filter -->
            <section class="mb-20" id="recipes">
                <h2 class="font-headline-md text-headline-md mb-8">Browse All Recipes</h2>
                
                <!-- Category Filter -->
                <div class="mb-8 flex flex-wrap gap-3">
                    <a href="{{ path('app_home') }}" class="px-4 py-2 rounded-full {% if not selectedCategory %}bg-primary text-on-primary{% else %}bg-surface-container-low text-on-surface-variant hover:bg-surface-container-high{% endif %} font-label-md transition-colors">
                        All Recipes
                    </a>
                    {% for category in categories %}
                        <a href="{{ path('app_home', {'categorie': category.id, 'page': 1}) }}" class="px-4 py-2 rounded-full {% if selectedCategory == category.id %}bg-primary text-on-primary{% else %}bg-surface-container-low text-on-surface-variant hover:bg-surface-container-high{% endif %} font-label-md transition-colors">
                            {{ category.nom }}
                        </a>
                    {% endfor %}
                </div>

                <!-- Search Form -->
                {% if search != '' %}
                    <div class="mb-6 p-4 bg-primary/10 rounded-lg flex items-center justify-between">
                        <span class="text-on-surface font-label-md">Searching for: <strong>{{ search }}</strong></span>
                        <a href="{{ path('app_home') }}" class="text-primary hover:text-primary-fixed-dim font-bold">Clear Search</a>
                    </div>
                {% endif %}

                <!-- Recipes Grid -->
                {% if recipes|length > 0 %}
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
                        {% for recipe in recipes %}
                            {% set imageUrl = recipe.imageName ? asset('uploads/recettes/' ~ recipe.imageName) : 'https://lh3.googleusercontent.com/aida-public/AB6AXuDFHS-KtAd8IhUzX49GVSQXPyswnXVgUhLUDy-EUAXXY-Z5HDXL2oLvdz4SQfgqeYazfHNq1FxQ4Eiexq0ewCQw9LEqMifymygbH_JbPmFCSyRMBIH879iEjcHckcZhhk4bs5b3hc28Bfz1oWjGe0eW6caTIrbnaUFnEn17sGfwsp6SMFYvclmnSFXXp_qciZcpdTgVQd5dzg9iOfg0nW9x2rXB1Y9fHjsPntjyg8i_XilMlfMawSB1XqoaMn_lRDCpoNowoNNzWvU' %}
                            <a href="{{ path('app_recette_show', {'id': recipe.id}) }}" class="bg-white rounded-2xl overflow-hidden recipe-shadow hover:-translate-y-1 transition-transform group cursor-pointer">
                                <div class="relative h-48 overflow-hidden bg-surface-container-low">
                                    <img class="w-full h-full object-cover group-hover:scale-110 transition-transform" alt="{{ recipe.titre }}" src="{{ imageUrl }}"/>
                                    <div class="absolute top-3 right-3 bg-primary text-on-primary px-3 py-1 rounded-full text-label-md font-bold">
                                        {{ recipe.categorie.nom }}
                                    </div>
                                </div>
                                <div class="p-4">
                                    <h3 class="font-bold text-on-surface mb-2 group-hover:text-primary transition-colors">{{ recipe.titre }}</h3>
                                    <p class="text-sm text-on-surface-variant mb-3 line-clamp-2">{{ recipe.description }}</p>
                                    <div class="flex items-center justify-between text-label-md text-on-surface-variant">
                                        <span class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">schedule</span>
                                            {{ recipe.tempsPreparation }}m
                                        </span>
                                        <span class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">group</span>
                                            {{ recipe.nbPersonnes }}
                                        </span>
                                    </div>
                                    <div class="mt-3 flex flex-wrap gap-1">
                                        {% for tag in recipe.tags|slice(0, 2) %}
                                            <span class="bg-secondary-container text-on-secondary-container px-2 py-1 rounded text-xs font-bold">{{ tag.nom }}</span>
                                        {% endfor %}
                                    </div>
                                </div>
                            </a>
                        {% endfor %}
                    </div>

                    <!-- Pagination -->
                    {% if totalPages > 1 %}
                        <div class="flex items-center justify-between mb-8">
                            <span class="font-label-md text-on-surface-variant">Showing {{ from }}-{{ to }} of {{ totalRecipes }} recipes</span>
                            <div class="flex items-center gap-2">
                                <a href="{{ page > 1 ? path('app_home', app.request.query.all|merge({'page': page - 1})) : '#' }}" class="p-2 rounded-lg border border-outline-variant hover:bg-surface-container-high transition-colors {% if page == 1 %}opacity-30 pointer-events-none{% endif %}">
                                    <span class="material-symbols-outlined" data-icon="chevron_left">chevron_left</span>
                                </a>
                                {% for pageNumber in 1..totalPages %}
                                    <a href="{{ path('app_home', app.request.query.all|merge({'page': pageNumber})) }}" class="w-10 h-10 rounded-lg {% if pageNumber == page %}bg-primary text-on-primary font-bold{% else %}hover:bg-surface-container-high text-on-surface-variant{% endif %} transition-colors flex items-center justify-center">{{ pageNumber }}</a>
                                {% endfor %}
                                <a href="{{ page < totalPages ? path('app_home', app.request.query.all|merge({'page': page + 1})) : '#' }}" class="p-2 rounded-lg border border-outline-variant hover:bg-surface-container-high transition-colors {% if page == totalPages %}opacity-30 pointer-events-none{% endif %}">
                                    <span class="material-symbols-outlined" data-icon="chevron_right">chevron_right</span>
                                </a>
                            </div>
                        </div>
                    {% endif %}
                {% else %}
                    <div class="text-center py-12 bg-surface-container-low rounded-2xl">
                        <span class="material-symbols-outlined text-6xl text-on-surface-variant mb-4 block">search_off</span>
                        <p class="text-on-surface-variant text-body-lg">No recipes found matching your criteria.</p>
                        <a href="{{ path('app_home') }}" class="mt-4 inline-block px-6 py-2 bg-primary text-on-primary rounded-xl font-label-md hover:scale-105 transition-transform">View All Recipes</a>
                    </div>
                {% endif %}
            </section>

            <section id="newsletter" class="bg-on-secondary-container text-white rounded-[40px] p-12 lg:p-20 relative overflow-hidden mb-20">
                <div class="relative z-10 max-w-2xl">
                    <h2 class="font-headline-xl text-headline-xl mb-6">Latest recipes straight to your inbox!</h2>
                    <p class="text-body-lg mb-10 opacity-90">Join 50,000+ home cooks. Your information won't be used for anything besides sharing delicious culinary inspiration.</p>
                    <form class="flex flex-col md:flex-row gap-4">
                        <input class="flex-1 px-6 py-4 rounded-2xl bg-white/10 border-white/20 text-white placeholder-white/60 focus:ring-secondary-fixed focus:border-secondary-fixed" placeholder="First name" type="text"/>
                        <input class="flex-1 px-6 py-4 rounded-2xl bg-white/10 border-white/20 text-white placeholder-white/60 focus:ring-secondary-fixed focus:border-secondary-fixed" placeholder="Email address" type="email"/>
                        <button class="px-10 py-4 bg-secondary-fixed text-on-secondary-fixed font-bold rounded-2xl hover:scale-105 transition-transform" type="submit">Subscribe</button>
                    </form>
                </div>
                <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-primary opacity-20 rounded-full blur-3xl"></div>
            </section>

            {{ include('home/_suggestions.html.twig', { suggestions: suggestions }) }}
        </main>

        {{ include('home/_footer.html.twig') }}

        <button class="fixed bottom-8 right-8 w-14 h-14 bg-primary text-on-primary rounded-full shadow-lg hover:scale-110 active:scale-95 transition-all flex items-center justify-center z-50" type="button">
            <span class="material-symbols-outlined" data-weight="fill">add_circle</span>
        </button>
    </div>
{% endblock %}