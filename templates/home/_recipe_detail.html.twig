<section class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-20 items-start max-w-container-max mx-auto px-margin-desktop pt-10" id="healthy">
    <div class="lg:col-span-8 relative rounded-3xl overflow-hidden recipe-shadow group">
        <img class="w-full h-[500px] object-cover group-hover:scale-105 transition-transform duration-700" alt="{{ featuredRecipe.title }}" src="{{ featuredRecipe.image }}"/>
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent flex flex-col justify-end p-10">
            <span class="inline-block bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full text-label-md w-fit mb-4">{{ featuredRecipe.badge }}</span>
            <h1 class="font-headline-xl text-headline-xl text-white mb-4">{{ featuredRecipe.title }}</h1>
            <div class="flex gap-6 text-white/90 text-label-md">
                <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[18px]">schedule</span> {{ featuredRecipe.prepTime }}</span>
                <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[18px]">restaurant</span> {{ featuredRecipe.servings }}</span>
                <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[18px]">bolt</span> {{ featuredRecipe.calories }}</span>
            </div>
        </div>
    </div>

    <div class="lg:col-span-4 bg-surface-container-low rounded-3xl p-8 recipe-shadow">
        <div class="flex justify-between items-center mb-6">
            <h2 class="font-headline-md text-headline-md text-on-surface">Ingredients</h2>
            <div class="flex items-center gap-2 bg-white px-3 py-1 rounded-full border border-outline-variant">
                <button class="material-symbols-outlined text-primary text-[20px]" type="button">remove_circle</button>
                <span class="text-label-md">1 Servings</span>
                <button class="material-symbols-outlined text-primary text-[20px]" type="button">add_circle</button>
            </div>
        </div>
        <ul class="space-y-4">
            {% for ingredient in ingredients %}
                <li class="flex items-start gap-3 group">
                    <span class="material-symbols-outlined text-primary" data-weight="fill">check_circle</span>
                    <span class="text-body-md text-on-surface-variant group-hover:text-on-surface transition-colors">{{ ingredient }}</span>
                </li>
            {% endfor %}
        </ul>
        <button class="w-full mt-8 py-3 rounded-xl border-2 border-primary text-primary font-bold hover:bg-primary hover:text-on-primary transition-all flex items-center justify-center gap-2" type="button">
            <span class="material-symbols-outlined">shopping_basket</span> Add to Shopping List
        </button>
    </div>

    <div class="lg:col-span-12">
        <section class="mb-20 mt-8" id="quick-meals">
            <h2 class="font-headline-md text-headline-md mb-2">Utensils</h2>
            <p class="text-on-surface-variant mb-8 font-body-md">Essential tools for this recipe.</p>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
                {% for utensil in utensils %}
                    <div class="bg-white p-6 rounded-2xl recipe-shadow text-center flex flex-col items-center">
                        <img class="w-24 h-24 object-contain mb-4" alt="{{ utensil.name }}" src="{{ utensil.image }}"/>
                        <span class="text-label-md font-bold">{{ utensil.name }}</span>
                    </div>
                {% endfor %}
            </div>
        </section>
    </div>
</section>