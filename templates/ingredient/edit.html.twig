{% extends 'base.html.twig' %}

{% block title %}RecipeHub Admin - Ingrédients{% endblock %}

{% block body %}
<main class="bg-background text-on-background min-h-screen flex-1 p-margin-desktop max-w-container-max mx-auto">
    <header class="mb-10 text-center flex flex-col items-center">
        <nav class="flex items-center text-on-surface-variant text-sm mb-4">
            <span class="hover:text-primary cursor-pointer">Admin</span>
            <span class="material-symbols-outlined text-sm mx-2">chevron_right</span>
            <span class="hover:text-primary cursor-pointer">Ingrédients</span>
            <span class="material-symbols-outlined text-sm mx-2">chevron_right</span>
            <span class="text-primary font-bold">Modifier</span>
        </nav>
        <h2 class="font-headline-xl text-headline-xl text-on-background">Ajouter/Modifier un Ingrédient</h2>
        <p class="font-body-md text-on-surface-variant mt-2 max-w-2xl">Créez des ingrédients liés à une recette précise pour garder la liste claire et cohérente.</p>
    </header>

    <div class="grid-cols-1 gap-gutter flex flex-col items-center">
        <section class="bg-surface-container-lowest rounded-xl p-8 recipe-shadow w-full max-w-3xl">
            {{ include('ingredient/_form.html.twig', {'button_label': 'Update'}) }}
            <div class="mt-6">
                {{ include('ingredient/_delete_form.html.twig') }}
            </div>
        </section>
    </div>
</main>
{% endblock %}
