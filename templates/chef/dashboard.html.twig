{% extends "base.html.twig" %}

{% block title %}Mon Tableau de Bord - RecipeHub{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50">
    <div class="flex">
        <!-- Sidebar -->
        <aside class="fixed left-0 top-0 h-screen w-16 bg-[#006d37] shadow-lg flex flex-col items-center py-8 gap-8">
            <a href="{{ path('app_home') }}" class="text-white hover:bg-[#005a2d] p-2 rounded-lg transition-colors" title="Accueil">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                </svg>
            </a>

            <a href="{{ path('app_chef_dashboard') }}" class="text-white bg-[#005a2d] p-2 rounded-lg" title="Mon Tableau de Bord">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/>
                </svg>
            </a>

            <a href="{{ path('app_chef_profile') }}" class="text-white hover:bg-[#005a2d] p-2 rounded-lg transition-colors" title="Mon Profil">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
            </a>

            <a href="{{ path('app_tags_index') }}" class="text-white hover:bg-[#005a2d] p-2 rounded-lg transition-colors" title="Étiquettes">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm0-13c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5z"/>
                </svg>
            </a>

            <div class="mt-auto">
                <a href="{{ path('app_logout') }}" class="text-red-200 hover:bg-red-600/20 p-2 rounded-lg transition-colors" title="Déconnexion">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/>
                    </svg>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 ml-16">
            <!-- Header -->
            <div class="bg-white border-b border-slate-200 p-6 sticky top-0 z-10">
                <div class="max-w-7xl mx-auto">
                    <div class="flex items-center justify-between">
                        <div>
                            <h1 class="text-3xl font-newsreader font-bold text-slate-900">Mon Tableau de Bord</h1>
                            <p class="text-slate-600 mt-1">Gérez vos recettes et votre profil</p>
                        </div>
                        <div class="flex items-center gap-4">
                            <a href="{{ path('app_recette_new') }}" class="bg-[#006d37] text-white px-4 py-2 rounded-lg hover:bg-[#005a2d] transition-colors flex items-center gap-2">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                                </svg>
                                Nouvelle Recette
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Section -->
            <div class="p-6">
                <div class="max-w-7xl mx-auto">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                        <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-recipe">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="text-sm text-slate-600 font-medium">Total des Recettes</p>
                                    <p class="text-3xl font-bold text-slate-900 mt-2">{{ totalRecipes }}</p>
                                </div>
                                <svg class="w-12 h-12 text-[#006d37]/20" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"/>
                                </svg>
                            </div>
                        </div>

                        <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-recipe">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="text-sm text-slate-600 font-medium">Profil</p>
                                    <p class="text-lg font-semibold text-slate-900 mt-2">{{ app.user.pseudo }}</p>
                                </div>
                                <svg class="w-12 h-12 text-[#006d37]/20" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                </svg>
                            </div>
                        </div>

                        <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-recipe">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="text-sm text-slate-600 font-medium">Actions</p>
                                    <div class="flex gap-2 mt-2">
                                        <a href="{{ path('app_chef_profile') }}" class="text-xs bg-[#006d37]/10 text-[#006d37] px-2 py-1 rounded hover:bg-[#006d37]/20 transition-colors">Profil</a>
                                        <a href="{{ path('app_tags_index') }}" class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded hover:bg-purple-200 transition-colors">Tags</a>
                                    </div>
                                </div>
                                <svg class="w-12 h-12 text-[#006d37]/20" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm0-13c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5z"/>
                                </svg>
                            </div>
                        </div>
                    </div>

                    <!-- Recettes Grid -->
                    <div class="mb-8">
                        <h2 class="text-2xl font-newsreader font-bold text-slate-900 mb-6">Mes Recettes</h2>

                        {% if recipes is empty %}
                            <div class="bg-white rounded-xl p-12 text-center border border-slate-200">
                                <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"/>
                                </svg>
                                <p class="text-slate-600">Vous n'avez pas encore de recettes.</p>
                                <a href="{{ path('app_recette_new') }}" class="inline-block mt-4 bg-[#006d37] text-white px-6 py-2 rounded-lg hover:bg-[#005a2d] transition-colors">
                                    Créer une recette
                                </a>
                            </div>
                        {% else %}
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                {% for recette in recipes %}
                                    <div class="bg-white rounded-xl overflow-hidden shadow-recipe hover:shadow-lg transition-shadow border border-slate-200 group">
                                        <!-- Image Section -->
                                        <div class="relative h-48 bg-gradient-to-br from-[#006d37]/5 to-[#006d37]/10 overflow-hidden">
                                            {% if recette.imageName %}
                                                <img src="/uploads/recettes/{{ recette.imageName }}" alt="{{ recette.titre }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                                            {% else %}
                                                <div class="w-full h-full flex items-center justify-center">
                                                    <svg class="w-16 h-16 text-[#006d37]/20" fill="currentColor" viewBox="0 0 24 24">
                                                        <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                                                    </svg>
                                                </div>
                                            {% endif %}
                                            <div class="absolute top-3 right-3">
                                                {% if recette.categorie %}
                                                    <span class="inline-block bg-[#006d37] text-white text-xs font-medium px-3 py-1 rounded-full">
                                                        {{ recette.categorie.nom }}
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>

                                        <!-- Content Section -->
                                        <div class="p-4">
                                            <h3 class="font-newsreader font-bold text-lg text-slate-900 line-clamp-2 mb-2">{{ recette.titre }}</h3>
                                            
                                            <p class="text-sm text-slate-600 line-clamp-2 mb-4">{{ recette.description }}</p>

                                            <!-- Recipe Details -->
                                            <div class="grid grid-cols-3 gap-3 mb-4 py-3 border-y border-slate-200">
                                                {% if recette.tempsPreparation %}
                                                    <div class="text-center">
                                                        <svg class="w-5 h-5 text-[#006d37] mx-auto mb-1" fill="currentColor" viewBox="0 0 24 24">
                                                            <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c0 .83-.67 1.5-1.5 1.5s-1.5-.67-1.5-1.5.67-1.5 1.5-1.5 1.5.67 1.5 1.5z"/>
                                                        </svg>
                                                        <p class="text-xs text-slate-600">{{ recette.tempsPreparation }} min</p>
                                                    </div>
                                                {% endif %}
                                                {% if recette.tempsCuisson %}
                                                    <div class="text-center">
                                                        <svg class="w-5 h-5 text-[#006d37] mx-auto mb-1" fill="currentColor" viewBox="0 0 24 24">
                                                            <path d="M13 5h8v8h-8V5zm0 10h8v8h-8v-8zM3 5h8v8H3V5zm0 10h8v8H3v-8z"/>
                                                        </svg>
                                                        <p class="text-xs text-slate-600">{{ recette.tempsCuisson }} min</p>
                                                    </div>
                                                {% endif %}
                                                {% if recette.nbPersonnes %}
                                                    <div class="text-center">
                                                        <svg class="w-5 h-5 text-[#006d37] mx-auto mb-1" fill="currentColor" viewBox="0 0 24 24">
                                                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                                        </svg>
                                                        <p class="text-xs text-slate-600">{{ recette.nbPersonnes }} pers</p>
                                                    </div>
                                                {% endif %}
                                            </div>

                                            <!-- Tags -->
                                            {% if recette.tags is not empty %}
                                                <div class="mb-4 flex flex-wrap gap-2">
                                                    {% for tag in recette.tags %}
                                                        <span class="inline-block text-xs font-medium px-2 py-1 rounded-full bg-slate-100 text-slate-700">
                                                            {{ tag.nom }}
                                                        </span>
                                                    {% endfor %}
                                                </div>
                                            {% endif %}

                                            <!-- Actions -->
                                            <div class="flex gap-2 pt-4 border-t border-slate-200">
                                                <a href="{{ path('app_recette_show', {'id': recette.id}) }}" class="flex-1 bg-[#006d37] text-white text-sm font-medium py-2 rounded-lg hover:bg-[#005a2d] transition-colors text-center">
                                                    Voir
                                                </a>
                                                <a href="{{ path('app_recette_edit', {'id': recette.id}) }}" class="flex-1 bg-slate-100 text-slate-700 text-sm font-medium py-2 rounded-lg hover:bg-slate-200 transition-colors text-center">
                                                    Modifier
                                                </a>
                                                <form method="POST" action="{{ path('app_recette_delete', {'id': recette.id}) }}" class="flex-1" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette recette ?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recette.id) }}">
                                                    <button type="submit" class="w-full bg-red-100 text-red-700 text-sm font-medium py-2 rounded-lg hover:bg-red-200 transition-colors">
                                                        Supprimer
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}

                        <!-- Pagination -->
                        {% if totalPages > 1 %}
                            <div class="mt-8 flex justify-center items-center gap-2">
                                {% if currentPage > 1 %}
                                    <a href="{{ path('app_chef_dashboard', {'page': 1}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">
                                        &laquo;
                                    </a>
                                    <a href="{{ path('app_chef_dashboard', {'page': currentPage - 1}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">
                                        &lt;
                                    </a>
                                {% endif %}

                                {% for page in 1..totalPages %}
                                    {% if page == currentPage %}
                                        <span class="px-3 py-2 rounded-lg bg-[#006d37] text-white font-medium">{{ page }}</span>
                                    {% elseif page >= currentPage - 2 and page <= currentPage + 2 %}
                                        <a href="{{ path('app_chef_dashboard', {'page': page}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">{{ page }}</a>
                                    {% endif %}
                                {% endfor %}

                                {% if currentPage < totalPages %}
                                    <a href="{{ path('app_chef_dashboard', {'page': currentPage + 1}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">
                                        &gt;
                                    </a>
                                    <a href="{{ path('app_chef_dashboard', {'page': totalPages}) }}" class="px-3 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors">
                                        &raquo;
                                    </a>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
{% endblock %}
